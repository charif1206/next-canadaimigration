# ─────────────────────────────────────────────────────────────────────────────
# Canada Immigration — Unified Next.js App
# .env.example  (copy to .env.local for development)
# ─────────────────────────────────────────────────────────────────────────────
# NEVER commit .env.local or .env.production with real secrets to git.
# All sensitive values must be injected at runtime (Render dashboard / CI/CD).
# ─────────────────────────────────────────────────────────────────────────────

# ─── App URLs ────────────────────────────────────────────────────────────────

# Base for client-side API calls (same Next.js server — keep as /api)
NEXT_PUBLIC_API_URL=/api

# Full public URL of this Next.js app — used in outgoing email links
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/immigration_db?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────

# Secret used to sign/verify JWTs (admin + client).
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"

# ─── Email (Nodemailer/SMTP) ──────────────────────────────────────────────────

# SMTP host (Mailtrap sandbox for dev, AWS SES / SendGrid / Brevo for prod)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM="Canada Immigration <noreply@immigration.ca>"

# Admin inbox that receives /api/contact form submissions
ADMIN_EMAIL=admin@example.com

# ─── Cloudinary (file uploads) ───────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
